{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(GDB) 调试主引擎 (xiaopengkernel)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/xiaopengkernel.exe",
            "args": [
                "${workspaceFolder}/demo/flexbox_integration.html"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(GDB) 调试布局测试 (test_layout)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/test_layout.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}